{
  "name": "x-basalt",
  "version": "0.1.0",
  "description": "纯 Node.js CLI：零依赖 Obsidian 运行时，解析 / 索引 / 查询（Dataview 子集）/ Skill 召回 Obsidian Vault",
  "type": "module",
  "bin": {
    "x-basalt": "dist/cli.js"
  },
  "files": [
    "dist",
    "skill-data",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "cli": "tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "skills:install": "node scripts/install-skills.mjs",
    "skills:install:global": "node scripts/install-skills.mjs --global",
    "prepare": "node scripts/setup-hooks.mjs",
    "prepublishOnly": "pnpm run typecheck && pnpm test && pnpm run build"
  },
  "keywords": [
    "obsidian",
    "markdown",
    "dataview",
    "cli",
    "sqlite",
    "wikilink"
  ],
  "license": "MIT",
  "author": "xnightsky",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chevrotain": "^12.0.0",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "cosmiconfig": "^9.0.2",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "json5": "^2.2.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "@ai-sdk/openai-compatible": "^3.0.1",
    "ai": "^7.0.6"
  }
}
