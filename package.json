{
  "name": "x-basalt",
  "version": "0.1.0",
  "description": "纯 Node.js CLI：零依赖 Obsidian 运行时，解析 / 索引 / 查询（Dataview 子集）/ Skill 召回 Obsidian Vault",
  "type": "module",
  "bin": {
    "x-basalt": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/parser.test.ts tests/indexer.test.ts tests/query.test.ts tests/skill.test.ts tests/config.test.ts",
    "cli": "tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "skills:install": "node scripts/install-skills.mjs"
  },
  "keywords": [
    "obsidian",
    "markdown",
    "dataview",
    "cli",
    "sqlite",
    "wikilink"
  ],
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@flowershow/remark-wiki-link": "^4.0.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "gray-matter": "^4.0.3",
    "json5": "^2.2.3",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
