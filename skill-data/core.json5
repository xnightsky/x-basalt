{
  // 本 CLI 的「自我说明书」skill：让 `x-basalt skills get core`（或 recall usage）经核心
  // SkillRecall 召回自身用法，方便 AI / 使用者无需外部文档即可学会驱动本工具。
  // 与 obsidian-base-spec 一样由 loader 列为「始终可召回」内置兜底。完整版见 docs/guides/usage.md。
  name: "core",
  description: "x-basalt CLI 自我说明书：parse/index/scan/query/skills/meta/watch/run/chat 各命令用法、变更编排管道、可选 AI 的自然语言 chat、DQL 子集、项目配置与示例。",
  triggers: [
    "usage",
    "help",
    "howto",
    "how-to",
    "manual",
    "guide",
    "readme",
    "说明书",
    "用法",
    "怎么用",
    "帮助",
    "命令",
    "指令",
    "cli",
    "x-basalt",
    "core",
    "getting-started",
    "quickstart",
    "parse",
    "index",
    "query",
    "skill",
    "watch",
    "recall",
    "meta",
    "frontmatter",
    "property",
    "properties",
    "元数据",
    "属性",
    "改写",
    "set",
    "rename",
    "normalize",
    "归一",
    "标准化",
    "tags",
    "aliases",
    "profile",
    "apply",
    "strategy",
    "策略",
    "模板",
    "pkm-note",
    "llm-wiki",
    "ssg-blog",
    "run",
    "pipeline",
    "orchestration",
    "编排",
    "管道",
    "migrate",
    "批量",
    "chat",
    "ai",
    "AI",
    "自然语言",
    "聊天",
    "对话",
    "llm",
    "agent",
    "gateway",
    "AI_GATEWAY",
    "AI_GATEWAY_API_KEY",
    "ollama",
    "model",
    "模型",
    "离线",
    "offline",
    "windows",
    "powershell",
    "linux",
    "env",
    "环境变量",
    "配置 ai",
    "怎么配",
    "example",
    "示例",
    "用例",
  ],
  patterns: [
    "x-basalt parse <file>",
    "x-basalt index <vault> --db <path>",
    "x-basalt query <dql> --db <path>",
    "x-basalt skills get <name>",
    "x-basalt meta set <file> <key> <value>",
    "x-basalt watch <vault> --on-change <cmd>",
    "x-basalt run --pipe actions=... [--apply]",
    'x-basalt chat "<自然语言>"  (需 AI_GATEWAY_API_KEY)',
  ],
  rules: [
    {
      pattern: "x-basalt <parse|index|scan|query|skills|meta|watch|run>",
      description: "零依赖 Obsidian 运行时的 Vault 工具。典型流程：index 建库 → query 查询；parse 看单文件 AST；scan 增量重扫；skills 召回规范；meta 读改 frontmatter（唯一写侧）；watch 监听增量；run 按声明式管道（源→去重→路由→动作链）处理一批变更。开发态 `pnpm run cli -- <command>`，构建后 `node dist/cli.js <command>`。出错统一打印 ✗ 并退出码 1。",
      examples: [
        "pnpm install && pnpm run build",
        "pnpm run cli -- index ./vault --db ./index.db",
        'node dist/cli.js query "LIST FROM #project" --db ./index.db',
      ],
    },
    {
      pattern: "parse <file> [--format json|yaml]",
      description: "解析单个 .md → { frontmatter, nodes }；nodes 含 wikilink/tag/callout/task/highlight/blockRef。--format 默认 json，可选 yaml。纯函数，不碰 DB。",
      examples: ["x-basalt parse note.md", "x-basalt parse note.md --format yaml"],
    },
    {
      pattern: "index <vault> [--db ./index.db] [--watch]",
      description: "全量扫描 Vault 下所有 .md 写入 SQLite，跳过 .obsidian/ 与隐藏文件；事务内先清空再写、失败回滚。--watch 建库后继续监听增量。",
      examples: ["x-basalt index ./vault --db ./index.db"],
    },
    {
      pattern: "scan <vault> [--db ./index.db] [--rehash] [--dry-run] [--json] [--pipe k=v]... [--apply]",
      description: "按需增量重索引（无需常驻 watch）：diff 文件系统 vs 库，只重扫新增/改动/删除文件，断点续扫，适合 cron/CI 触发。默认 mtime+size 判变化、--rehash 内容兜底、--dry-run 只报告不写库、--json 结构化差异。--pipe 用管道处理 scan 出的变更（替代默认仅 index）：--pipe actions=… 内联 或 --pipe use=<name> 引用配置；--apply 才落盘。管道语义同 run。",
      examples: [
        "x-basalt scan ./vault --dry-run",
        "x-basalt scan ./vault --rehash --json",
        "x-basalt scan ./vault --pipe use=maintain",
      ],
    },
    {
      pattern: "query <dql> [--db <path>] [--offset <n>] [--size <n>] [--vault <path>]",
      description: '执行 DQL 子集 → 参数化 SQL → JSON { type, columns, total, offset, size, returned, hasMore, rows }；聚合字段已解析为数组。total=命中总数（独立 COUNT，不随分页变）——**数总量直接读 total，别 LIST 全量再数**。--offset/--size 在引擎层分页（不改 DQL 文法，外层包 LIMIT/OFFSET）：不传 size=全量返回（向后兼容），翻页 offset+=size，hasMore 标示还有更多。--db 只读打开；--vault 接受但不使用。文法：LIST|TABLE <fields> FROM (#tag|[[link]]|"folder") WHERE <cond> GROUP BY <field> SORT <field> ASC|DESC LIMIT <n>。',
      examples: [
        "x-basalt query \"LIST FROM #project WHERE status = 'active' SORT file.mtime DESC LIMIT 10\" --db ./index.db",
        "x-basalt query 'LIST FROM \"\"' --size 50 --offset 0 --db ./index.db   # 分页：每页 50，读 total 知总量",
        "x-basalt query 'TABLE count() FROM \"\" GROUP BY file.extension' --db ./index.db   # 计数惯用法",
      ],
    },
    {
      pattern: "计数 / 分页（数总量别全量 LIST）",
      description: '要"有多少"绝不全量 LIST 再数：① 任何 query 结果都带 total（命中总数）——读它即可；② 全库/分组计数用 `TABLE count() FROM "" GROUP BY <字段>`（count()/length(rows) 是 GROUP BY 聚合列，单独 `TABLE count()` 不带 GROUP BY 无效）。分页：CLI 用 `--offset/--size`，chat 的 query/scan 工具用 `offset/size`（默认 size=50，上限 500，size=0 只回 total/counts）。chat 的 scan 工具还返回 counts{added,modified,deleted,unchanged}（标量、永不截断）——"多少新增/未索引"直接读 counts。DQL 自身只有 LIMIT、无 OFFSET，分页一律在 CLI/工具层。',
      examples: [
        'x-basalt query \'TABLE count() FROM "" GROUP BY file.extension\' --db ./index.db',
        'x-basalt query \'LIST FROM ""\' --size 100 --offset 100 --db ./index.db',
      ],
    },
    {
      pattern: "skills (list | get <name> [--all] | recall <keyword> | path [name]) [--json]",
      description: "召回规范知识库（内置 obsidian-base-spec + 本说明书 core）。list 列出 name—description；get <name> 按名输出该 skill 完整内容（--all 输出全部）；recall <kw> 模糊召回（Fuse，容拼写错、按相关性排序）；path 打印数据目录（带 name 打印该文件路径）。默认输出人类/AI 可读 Markdown，加 --json 切换结构化。本说明书自身即一个可召回 skill —— `skills get core` 直接读到本 CLI 完整用法。",
      examples: [
        "x-basalt skills",
        "x-basalt skills get core",
        "x-basalt skills get obsidian-base-spec",
        "x-basalt skills recall wikilink",
        "x-basalt skills list --json",
      ],
    },
    {
      pattern: "meta (get|set|unset|rename|normalize) <file> ...",
      description: "读/改单文件 frontmatter（元数据头），唯一写侧命令。get [key] 读（缺省读全部，缺失键输出 null）；set <key> <value> 增改（存在则原位更新、否则追加）；unset <key> 删；rename <old> <new> 改键名（保位置/值，源缺失或目标已存在则报错）；normalize 归一。写只动 frontmatter、正文逐字节不动；YAML 往返保留键序与注释、需引号的值（如 [[链接]]）自动加引号；原子写；--dry-run 只打印将写入内容不落盘。set --type string|number|boolean|null|list|auto（默认 auto 保守推断，不识别 yes/no/on/off 避免 Norway 陷阱）。normalize 默认 ON：tags/aliases/cssclasses 列表化（tags/cssclasses 标量按空白/逗号拆、aliases 不拆）、tags 去 #、去重、单数键 tag/alias/cssclass→复数键迁移；opt-in --sort-keys 排序顶层键。非法 YAML 的写操作拒绝执行、文件不变。幂等。仅顶层扁平键。",
      examples: [
        "x-basalt meta get note.md",
        "x-basalt meta set note.md status active",
        "x-basalt meta set note.md rank 3 --type number",
        'x-basalt meta set note.md tags "a, b, c" --type list',
        "x-basalt meta rename note.md tag tags",
        "x-basalt meta normalize note.md",
        "x-basalt meta set note.md status done --dry-run",
      ],
    },
    {
      pattern: "meta profile (list|show <name>) / meta apply <profile> <file> [--set k=v]...",
      description: "元数据策略（profile）= 一套现成约定（模板+规范）。x-basalt 只「告知」、不调 LLM——你（AI）读规范后自己决定补什么。内置 3 套：pkm-note(Obsidian,第一推荐)、llm-wiki(OKF)、ssg-blog(SSG)。用法：先 `meta profile show <name>` 读该约定的字段/必填/语义/可额外补什么；再 `meta apply <profile> <file>` —— 机械补 created/modified/pubDate/timestamp/sha256（按文件时间/正文）+ 你用 `--set key=value`(可重复) 补语义字段（type/title/description/tags…）和额外字段。--set 按 profile 字段类型转值（list 自动按逗号拆）、且**显式覆盖**已有值；apply 收尾自动 normalize（产出既合规又齐全）。报告 filled/overridden/仍缺。典型流程：apply 看“仍缺”→ profile show 读规范 → 读文档内容 → apply --set 补齐。",
      examples: [
        "x-basalt meta profile list",
        "x-basalt meta profile show pkm-note",
        "x-basalt meta apply pkm-note note.md",
        "x-basalt meta apply pkm-note note.md --set tags=area/work,moc --set status=active",
        'x-basalt meta apply llm-wiki note.md --set type=note --set description="一句话摘要"',
      ],
    },
    {
      pattern: "watch <vault> [--db ./index.db] [--on-change <cmd>] [--pipe k=v]... [--apply]",
      description: "先全量 rebuild 再监听；add/change 先增量更新索引再触发回调，unlink 删记录。--on-change 命令模板用 {file} 占位替换变更文件路径。--pipe 用管道维护（替代裸 shell）：--pipe actions=… 或 --pipe use=<name>；常驻自动改文件需 --apply，Ctrl+C 优雅退出。管道语义同 run。前台运行。",
      examples: [
        'x-basalt watch ./vault --db ./index.db --on-change "echo changed {file}"',
        "x-basalt watch ./vault --pipe use=maintain",
      ],
    },
    {
      pattern: "run [--pipe k=v]... [--apply] [--vault <path>] [--db <path>] [--json]",
      description: "按管道处理一批变更。--pipe k=v（可重复）定义管道：use=<name> 引用配置段、actions=a,b 动作链(必填)、where=DQL 选文件、on=类型、paths=glob、concurrency=N；命令行 --pipe 是规范、配置段 pipelines.<name> 是命名快照（一一对应）。源：默认 scan 全库 diff，--pipe where=/paths= 切手动源。流程 源→去重(同文件折叠)→路由→动作链(index/normalize/parse)。写动作默认 dry-run，--apply 才落盘。--json 报告；失败退出码 1。原 migrate = run --pipe actions=… --pipe where=…。",
      examples: [
        'x-basalt run --pipe actions=index,normalize --pipe where="LIST FROM #pkm" --apply --vault ./vault',
        "x-basalt run --pipe use=maintain --apply --vault ./vault",
      ],
    },
    {
      pattern: 'chat ["<自然语言>"] [--model <name>] [--max-steps <n>] [--db <path>] [--vault <path>]',
      description: "可选 AI 子命令（如何用）：用自然语言驱动既有原语（读 query/parse/scan/meta_get/skills_recall + 写 meta_set/unset/rename/normalize/apply + 批量 pipeline_run）跑 plan→act→observe 循环。带参=单发翻译执行即退；省略参数=进 REPL（quit/exit/q 退出）。最小可选 AI：内核零 AI、chat 隔离懒加载 SDK；没配 key=本命令禁用但其余命令全功能照常（需 AI_GATEWAY_API_KEY，--model 覆盖模型）。写动作直接落盘、无逐个确认弹窗——安全靠流式可观测 + Ctrl+C 中断在途 + 既有原子写（kill 不损坏文件）+ git 兜底。**只做一次性操作，不支持常驻 watch/监听**：绝不让它跑 watch 或 index --watch 这类常驻命令——会永不返回、把 chat 挂死；持续维护 vault 用独立的 watch / scan --pipe。能力边界：当前做结构化任务（DQL/元数据/规范），按笔记正文全文检索依赖 FTS5（未落地）。**如何配置（AI_GATEWAY_* 三变量、Linux/macOS 与 Windows 各平台设法与持久化、离线本地端点）见 docs/guides/ai-and-skills.md 第四节。**",
      examples: [
        'x-basalt chat "把 projects 下 status 为空的笔记列出来"',
        'x-basalt chat "给 2024 年的周报都补上 tag weekly"',
        'x-basalt chat --model anthropic/claude-opus-4.8 "..."',
        "x-basalt chat   # 省略参数进 REPL，连续提问，quit/exit/q 退出",
      ],
    },
    {
      pattern: "DQL 操作符与隐式字段",
      description: '操作符：= != < > <= >= / contains icontains startswith endswith / AND OR NOT / regexmatch(field,"pattern")。判有无：裸字段真值 `WHERE field`（对标官方 isTruthy：缺失/null/0/空串/空数组 皆 falsy）、`!field`（无或 falsy）；显式 null 判断 `field = null`/`!= null`（测键是否存在，把 0/空串视为「有」，与 !field 在 falsy 值上相反——问「多少篇没有 X」默认用 `!field`）。隐式字段：file.name/path/folder/extension/size/mtime/ctime/tags/inlinks/outlinks/tasks/frontmatter 与任意 frontmatter 标量。**字段值可来自 frontmatter 或正文 inline fields（`key:: value` 整行/[方括号]/(圆括号) 三形态，同一命名空间）**：同名 frontmatter 胜、inline 兜底；inline 值恒 TEXT 字典序比较（10 vs 9 会错）、同名 last-wins、key 仅 [A-Za-z0-9_]+；真值/存在性同样计入 inline；旧库要查 inline 需重跑 index 回填。判「完全没有 frontmatter」用 `!file.frontmatter`（别跟「未被索引」混淆，后者用 scan 工具的 counts/byDir；inline 字段也不进 file.frontmatter 对象）。FROM #a 前缀命中 #a/b；FROM "F" 含子文件夹；FROM [[N]] 取指向 N 的反向链接。',
      examples: [
        'LIST WHERE contains(file.tags, "area")',
        'LIST WHERE !index          // 没有 index（缺失或 falsy）',
        'LIST WHERE !file.frontmatter // 完全没有 frontmatter（不是"没被索引"）',
        'TABLE rating WHERE rating > "4"  // rating 可来自 frontmatter 或正文 (rating:: 5)',
        'LIST WHERE regexmatch(file.name, "^20[0-9]{2}-")',
        "TABLE file.inlinks FROM [[Index]]",
      ],
    },
    {
      pattern: "项目配置 .x-basalt/config.yaml",
      description: "项目本地配置默认放隐藏目录 .x-basalt/（不入 git，类比 .obsidian/），免去重复传参。默认 YAML，也支持 JSON5/JSON；扁平 .x-basalt.yaml 亦可。键：db / vault / skillPath / format / onChange。索引默认落 .x-basalt/index.db（目录自动建）。CLI 从 cwd 向上查找，全局回退 ~/.x-basalt/config.yaml。优先级：flag > 项目配置 > 全局配置 > 内置默认。",
      examples: [
        "cp .x-basalt/config.example.yaml .x-basalt/config.yaml",
        "# .x-basalt/config.yaml 内写 vault: ./my-vault 后，x-basalt index / query 可零参数运行",
      ],
    },
    {
      pattern: "限制与非目标",
      description: "frontmatter 日期以 ISO 存储（精确等值不命中，用范围/前缀）；代码块内 #tag/==..== 不剔除；链接按 basename 解析；file.tasks 仅显示不可过滤；file.day 等、多字段 SORT、length() 数值比较为非目标，遇到明确报错。完整说明见 docs/guides/usage.md。",
      examples: ["x-basalt query \"LIST WHERE due >= '2026-06-01'\" --db ./index.db"],
    },
  ],
  metadata: {
    doc: "docs/guides/usage.md",
    commands: ["parse", "index", "scan", "query", "skills", "meta", "watch", "run", "chat"],
    self_recall: true,
  },
}
