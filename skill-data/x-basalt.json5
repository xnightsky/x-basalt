{
  // 本 CLI 的「自我说明书」skill：让 `x-basalt skills get x-basalt`（或 recall usage）经核心
  // SkillRecall 召回自身用法，方便 AI / 使用者无需外部文档即可学会驱动本工具。
  // 与 obsidian-base-spec 一样由 loader 列为「始终可召回」内置兜底。完整版见 docs/guides/usage.md。
  name: "x-basalt",
  description: "x-basalt CLI 自我说明书：parse/index/scan/query/skills/meta/watch/run 各命令用法、变更编排管道、DQL 子集、项目配置与示例。",
  triggers: [
    "usage", "help", "howto", "how-to", "manual", "guide", "readme",
    "说明书", "用法", "怎么用", "帮助", "命令", "指令",
    "cli", "x-basalt", "getting-started", "quickstart",
    "parse", "index", "query", "skill", "watch", "recall",
    "meta", "frontmatter", "property", "properties", "元数据", "属性", "改写", "set", "rename",
    "normalize", "归一", "标准化", "tags", "aliases",
    "profile", "apply", "strategy", "策略", "模板", "pkm-note", "llm-wiki", "ssg-blog",
    "run", "pipeline", "orchestration", "编排", "管道", "migrate", "批量",
    "example", "示例", "用例",
  ],
  patterns: [
    "x-basalt parse <file>",
    "x-basalt index <vault> --db <path>",
    "x-basalt query <dql> --db <path>",
    "x-basalt skills get <name>",
    "x-basalt meta set <file> <key> <value>",
    "x-basalt watch <vault> --on-change <cmd>",
    "x-basalt run <pipeline> [--where <dql>]",
  ],
  rules: [
    {
      pattern: "x-basalt <parse|index|scan|query|skills|meta|watch|run>",
      description: "零依赖 Obsidian 运行时的 Vault 工具。典型流程：index 建库 → query 查询；parse 看单文件 AST；scan 增量重扫；skills 召回规范；meta 读改 frontmatter（唯一写侧）；watch 监听增量；run 按声明式管道（源→去重→路由→动作链）处理一批变更。开发态 `pnpm run cli -- <command>`，构建后 `node dist/cli.js <command>`。出错统一打印 ✗ 并退出码 1。",
      examples: [
        "pnpm install && pnpm run build",
        "pnpm run cli -- index ./vault --db ./index.db",
        "node dist/cli.js query \"LIST FROM #project\" --db ./index.db",
      ],
    },
    {
      pattern: "parse <file> [--format json|yaml]",
      description: "解析单个 .md → { frontmatter, nodes }；nodes 含 wikilink/tag/callout/task/highlight/blockRef。--format 默认 json，可选 yaml。纯函数，不碰 DB。",
      examples: ["x-basalt parse note.md", "x-basalt parse note.md --format yaml"],
    },
    {
      pattern: "index <vault> [--db ./index.db] [--watch]",
      description: "全量扫描 Vault 下所有 .md 写入 SQLite，跳过 .obsidian/ 与隐藏文件；事务内先清空再写、失败回滚。--watch 建库后继续监听增量。",
      examples: ["x-basalt index ./vault --db ./index.db"],
    },
    {
      pattern: "scan <vault> [--db ./index.db] [--rehash] [--dry-run] [--json] [--pipeline <name>]",
      description: "按需增量重索引（无需常驻 watch）：diff 文件系统 vs 库，只重扫新增/改动/删除文件，断点续扫，适合 cron/CI 触发。默认 mtime+size 判变化、--rehash 内容兜底、--dry-run 只报告不写库、--json 结构化差异。--pipeline 用配置 pipelines 段的声明式管道处理 scan 出的变更（替代默认仅 index 落库），一次性 scan 源编排，等价 run <pipeline> 不带 --where/--paths。",
      examples: [
        "x-basalt scan ./vault --dry-run",
        "x-basalt scan ./vault --rehash --json",
        "x-basalt scan ./vault --pipeline maintain",
      ],
    },
    {
      pattern: "query <dql> --db <path> [--vault <path>]",
      description: "执行 DQL 子集 → 参数化 SQL → JSON { type, columns, rows }；聚合字段已解析为数组。--db 必填且只读打开；--vault 接受但不使用。文法：LIST|TABLE <fields> FROM (#tag|[[link]]|\"folder\") WHERE <cond> SORT <field> ASC|DESC LIMIT <n>。",
      examples: [
        "x-basalt query \"LIST FROM #project WHERE status = 'active' SORT file.mtime DESC LIMIT 10\" --db ./index.db",
        "x-basalt query 'TABLE status, due FROM \"Projects\" SORT file.name ASC' --db ./index.db",
      ],
    },
    {
      pattern: "skills (list | get <name> [--all] | recall <keyword> | path [name]) [--json]",
      description: "召回规范知识库（内置 obsidian-base-spec + 本说明书 x-basalt）。list 列出 name—description；get <name> 按名输出该 skill 完整内容（--all 输出全部）；recall <kw> 模糊召回（Fuse，容拼写错、按相关性排序）；path 打印数据目录（带 name 打印该文件路径）。默认输出人类/AI 可读 Markdown，加 --json 切换结构化。本说明书自身即一个可召回 skill —— `skills get x-basalt` 直接读到本 CLI 完整用法。",
      examples: [
        "x-basalt skills",
        "x-basalt skills get x-basalt",
        "x-basalt skills get obsidian-base-spec",
        "x-basalt skills recall wikilink",
        "x-basalt skills list --json",
      ],
    },
    {
      pattern: "meta (get|set|unset|rename|normalize) <file> ...",
      description: "读/改单文件 frontmatter（元数据头），唯一写侧命令。get [key] 读（缺省读全部，缺失键输出 null）；set <key> <value> 增改（存在则原位更新、否则追加）；unset <key> 删；rename <old> <new> 改键名（保位置/值，源缺失或目标已存在则报错）；normalize 归一。写只动 frontmatter、正文逐字节不动；YAML 往返保留键序与注释、需引号的值（如 [[链接]]）自动加引号；原子写；--dry-run 只打印将写入内容不落盘。set --type string|number|boolean|null|list|auto（默认 auto 保守推断，不识别 yes/no/on/off 避免 Norway 陷阱）。normalize 默认 ON：tags/aliases/cssclasses 列表化（tags/cssclasses 标量按空白/逗号拆、aliases 不拆）、tags 去 #、去重、单数键 tag/alias/cssclass→复数键迁移；opt-in --sort-keys 排序顶层键。非法 YAML 的写操作拒绝执行、文件不变。幂等。仅顶层扁平键。",
      examples: [
        "x-basalt meta get note.md",
        "x-basalt meta set note.md status active",
        "x-basalt meta set note.md rank 3 --type number",
        "x-basalt meta set note.md tags \"a, b, c\" --type list",
        "x-basalt meta rename note.md tag tags",
        "x-basalt meta normalize note.md",
        "x-basalt meta set note.md status done --dry-run",
      ],
    },
    {
      pattern: "meta profile (list|show <name>) / meta apply <profile> <file> [--set k=v]...",
      description: "元数据策略（profile）= 一套现成约定（模板+规范）。x-basalt 只「告知」、不调 LLM——你（AI）读规范后自己决定补什么。内置 3 套：pkm-note(Obsidian,第一推荐)、llm-wiki(OKF)、ssg-blog(SSG)。用法：先 `meta profile show <name>` 读该约定的字段/必填/语义/可额外补什么；再 `meta apply <profile> <file>` —— 机械补 created/modified/pubDate/timestamp/sha256（按文件时间/正文）+ 你用 `--set key=value`(可重复) 补语义字段（type/title/description/tags…）和额外字段。--set 按 profile 字段类型转值（list 自动按逗号拆）、且**显式覆盖**已有值；apply 收尾自动 normalize（产出既合规又齐全）。报告 filled/overridden/仍缺。典型流程：apply 看“仍缺”→ profile show 读规范 → 读文档内容 → apply --set 补齐。",
      examples: [
        "x-basalt meta profile list",
        "x-basalt meta profile show pkm-note",
        "x-basalt meta apply pkm-note note.md",
        "x-basalt meta apply pkm-note note.md --set tags=area/work,moc --set status=active",
        "x-basalt meta apply llm-wiki note.md --set type=note --set description=\"一句话摘要\"",
      ],
    },
    {
      pattern: "watch <vault> [--db ./index.db] [--on-change <cmd>] [--pipeline <name>]",
      description: "先全量 rebuild 再监听；add/change 先增量更新索引再触发回调，unlink 删记录。--on-change 命令模板用 {file} 占位替换变更文件路径。--pipeline 用配置 pipelines 段的声明式管道维护（替代裸 shell）：启动先 scan 建基线，常驻编排，Ctrl+C 优雅退出。前台运行。",
      examples: [
        "x-basalt watch ./vault --db ./index.db --on-change \"echo changed {file}\"",
        "x-basalt watch ./vault --pipeline maintain",
      ],
    },
    {
      pattern: "run <pipeline> [--where <dql>] [--paths <p...>] [--json]",
      description: "按配置 pipelines 段的声明式管道处理一批变更：源（默认 scan 全库 diff；--where 用 DQL 选文件、--paths 用列表作手动源）→ 去重（同文件折叠）→ 路由（事件类型/glob/DQL）→ 执行内建动作链（index/normalize/parse…）。写动作默认 dry-run（管道配置 dryRun:false 才落盘）。--json 输出结构化报告；有失败退出码 1。原 migrate（语义选一批改造）= run --where。",
      examples: [
        "x-basalt run maintain --vault ./vault",
        "x-basalt run apply-pkm --where \"LIST FROM #pkm\" --vault ./vault",
      ],
    },
    {
      pattern: "DQL 操作符与隐式字段",
      description: "操作符：= != < > <= >= / contains icontains startswith endswith / AND OR NOT / regexmatch(field,\"pattern\")。隐式字段：file.name/path/folder/extension/size/mtime/ctime/tags/inlinks/outlinks/tasks 与任意 frontmatter 标量。FROM #a 前缀命中 #a/b；FROM \"F\" 含子文件夹；FROM [[N]] 取指向 N 的反向链接。",
      examples: [
        "LIST WHERE contains(file.tags, \"area\")",
        "LIST WHERE regexmatch(file.name, \"^20[0-9]{2}-\")",
        "TABLE file.inlinks FROM [[Index]]",
      ],
    },
    {
      pattern: "项目配置 .x-basalt/config.yaml",
      description: "项目本地配置默认放隐藏目录 .x-basalt/（不入 git，类比 .obsidian/），免去重复传参。默认 YAML，也支持 JSON5/JSON；扁平 .x-basalt.yaml 亦可。键：db / vault / skillPath / format / onChange。索引默认落 .x-basalt/index.db（目录自动建）。CLI 从 cwd 向上查找，全局回退 ~/.x-basalt/config.yaml。优先级：flag > 项目配置 > 全局配置 > 内置默认。",
      examples: [
        "cp .x-basalt/config.example.yaml .x-basalt/config.yaml",
        "# .x-basalt/config.yaml 内写 vault: ./my-vault 后，x-basalt index / query 可零参数运行",
      ],
    },
    {
      pattern: "限制与非目标",
      description: "frontmatter 日期以 ISO 存储（精确等值不命中，用范围/前缀）；代码块内 #tag/==..== 不剔除；链接按 basename 解析；file.tasks 仅显示不可过滤；file.day 等、多字段 SORT、length() 数值比较为非目标，遇到明确报错。完整说明见 docs/guides/usage.md。",
      examples: ["x-basalt query \"LIST WHERE due >= '2026-06-01'\" --db ./index.db"],
    },
  ],
  metadata: {
    doc: "docs/guides/usage.md",
    commands: ["parse", "index", "scan", "query", "skills", "meta", "watch", "run"],
    self_recall: true,
  },
}
